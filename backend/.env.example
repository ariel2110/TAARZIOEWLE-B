APP_NAME=LocalBiz AutoSite Platform
ENVIRONMENT=development
API_V1_PREFIX=/api/v1
USE_POSTGRES=true
DATABASE_URL=
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=localbiz
POSTGRES_USER=localbiz
POSTGRES_PASSWORD=localbiz
FRONTEND_ADMIN_URL=http://localhost:5173
FRONTEND_CUSTOMER_URL=http://localhost:5174
FRONTEND_PUBLIC_URL=http://localhost:5175
ADMIN_DEV_TOKEN=dev-admin-token
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=720

# ── Portal / Odin (tazo-app.com gateway) ───────────────────────────────────────
# Shared secret injected by Traefik (inject-internal middleware) — must match TRAEFIK_INTERNAL_KEY there.
INTERNAL_KEY=

# RS256 PEM public key from the Odin (AORDIIENL) auth server — validates Bearer SSO tokens.

# Paste as one line with \n for line breaks, e.g.: -----BEGIN PUBLIC KEY-----\nMIIB...\n-----END PUBLIC KEY-----
ODIN_JWT_PUBLIC_KEY=

ADMIN_SEED_EMAIL=ar.2110@gmail.com
ADMIN_SEED_NAME=Ariel
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URL=http://localhost:8000/api/v1/auth/google/callback
AUTO_CREATE_TABLES=false
AUTO_SEED_DEMO_DATA=false

# ── LLM Providers ─────────────────────────────────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
XAI_API_KEY=

# ── Search & Data ─────────────────────────────────────────────────────────────
GOOGLE_PLACES_API_KEY=
SERPER_API_KEY=
APIFY_API_TOKEN=
FIRECRAWL_API_KEY=        # https://firecrawl.dev — scrapes official business websites for images/menu
FACEBOOK_ACCESS_TOKEN=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# ── WhatsApp (Meta Cloud API) ─────────────────────────────────────────────────
# Get from: Meta Business Manager → WhatsApp → API Setup
META_WA_PHONE_NUMBER_ID=          # Phone Number ID (numeric)
META_WA_ACCESS_TOKEN=             # System User permanent token
WHATSAPP_VERIFY_TOKEN=tazo-web-verify
WHATSAPP_OWNER_PHONE=             # Admin phone (Israeli format: 0521234567)

# Evolution API (DEPRECATED — kept for reference, do not use)
# EVOLUTION_API_URL=
# EVOLUTION_API_KEY=
# EVOLUTION_INSTANCE=

# ── Morning (Payments) ────────────────────────────────────────────────────────
MORNING_API_KEY=
MORNING_API_SECRET=
MORNING_WEBHOOK_SECRET=
MORNING_FIXED_PAYMENT_URL=https://mrng.to/Afe6Dg21q0
MORNING_SUCCESS_URL=https://tazo-web.com/success
MORNING_CANCEL_URL=https://tazo-web.com

# ── Infrastructure ────────────────────────────────────────────────────────────
HOSTINGER_API_TOKEN=
SERVER_PUBLIC_IP=
